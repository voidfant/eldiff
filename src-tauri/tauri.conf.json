{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ElDiff",
  "version": "1.0.0",
  "identifier": "com.konstantin.eldiff",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ElDiff",
        "width": 1440,
        "height": 960,
        "minWidth": 1160,
        "minHeight": 760,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 20
        }
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
